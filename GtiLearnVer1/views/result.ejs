<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <main class="container">
      <h1>Calculation Result</h1>

      <div class="card result-box">
        <p><strong>A:</strong> <%= a %></p>
        <p><strong>B:</strong> <%= b %></p>
        <p>
          <strong>Operation:</strong> <%= operation === "add" ? "Add (+)" :
          "Subtract (-)" %>
        </p>
        <hr />
        <p class="result"><strong>Result:</strong> <%= result %></p>
      </div>

      <a href="/" class="back-link">Back to form</a>
    </main>
  </body>
</html>
