<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="container">
    <h1>Calculator MVC</h1>
    <p>Only add and subtract.</p>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form action="/calculate" method="POST" class="card">
      <label for="a">Number A</label>
      <input id="a" name="a" type="number" step="any" required value="<%= values.a %>" />

      <label for="b">Number B</label>
      <input id="b" name="b" type="number" step="any" required value="<%= values.b %>" />

      <label for="operation">Operation</label>
      <select id="operation" name="operation">
        <option value="add" <%= values.operation === "add" ? "selected" : "" %>>Add (+)</option>
        <option value="subtract" <%= values.operation === "subtract" ? "selected" : "" %>>Subtract (-)</option>
      </select>

      <button type="submit">Calculate</button>
    </form>
  </main>
</body>
</html>
